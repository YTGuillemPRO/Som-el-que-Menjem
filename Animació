<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Faig 2</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@900&display=swap" rel="stylesheet">
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        html,body{width:100%;height:100%;overflow:hidden;background:#000}
        canvas{display:block}
        #startBtn{
            position:fixed;top:0;left:0;width:100%;height:100%;
            background:rgba(5,8,16,.92);z-index:100;
            display:flex;align-items:center;justify-content:center;
            cursor:pointer;border:none;color:#fff;font-family:'Cinzel',serif;
            font-size:clamp(22px,4vw,38px);letter-spacing:3px;
            transition:opacity .6s;
        }
        #startBtn.hide{opacity:0;pointer-events:none}
    </style>
</head>
<body>
<canvas id="c"></canvas>
<button id="startBtn">Iniciar Animación</button>
<script>
(()=>{
    const cvs=document.getElementById('c'), ctx=cvs.getContext('2d'), btn=document.getElementById('startBtn');
    let W,H,bGY;
    
    // Estado
    let isStarted = false, t0 = 0;
    let impactPlayed = false, chordPlayed = false;
    let rainDrops = [];
    
    // Audio
    let audioCtx=null, rainNode=null, rainGain=null;

    const lerp=(a,b,t)=>a+(b-a)*t;
    const clamp=(v,a,b)=>Math.max(a,Math.min(b,v));
    const eo3=t=>1-Math.pow(1-t,3);

    function resize(){W=cvs.width=innerWidth;H=cvs.height=innerHeight;bGY=H*.75;}
    window.addEventListener('resize', resize);
    resize();

    // --- AUDIO SEGURO ---
    function initAudio(){
        try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) {}
    }
    function playImpact(){
        if(!audioCtx) return;
        try {
            const n=audioCtx.currentTime;
            const o=audioCtx.createOscillator(); o.type='sine'; 
            o.frequency.setValueAtTime(60,n); o.frequency.exponentialRampToValueAtTime(20,n+0.3);
            const g=audioCtx.createGain(); g.gain.setValueAtTime(0.5,n); g.gain.exponentialRampToValueAtTime(0.01,n+0.3);
            o.connect(g); g.connect(audioCtx.destination); o.start(n); o.stop(n+0.3);
        } catch(e) {}
    }
    function startRainAudio(){
        if(!audioCtx||rainNode) return;
        try {
            const buf=audioCtx.createBuffer(1,audioCtx.sampleRate*2,audioCtx.sampleRate); 
            const d=buf.getChannelData(0);
            for(let i=0;i<d.length;i++) d[i]=Math.random()*2-1;
            rainNode=audioCtx.createBufferSource(); rainNode.buffer=buf; rainNode.loop=true;
            const f=audioCtx.createBiquadFilter(); f.type='highpass'; f.frequency.value=5000;
            rainGain=audioCtx.createGain(); rainGain.gain.value=0;
            rainNode.connect(f); f.connect(rainGain); rainGain.connect(audioCtx.destination); rainNode.start();
        } catch(e) {}
    }
    function playChord(){
        if(!audioCtx) return;
        try {
            const n=audioCtx.currentTime;
            [523.25, 659.25, 783.99].forEach((freq,i)=>{
                const o=audioCtx.createOscillator(); o.type='sine'; o.frequency.value=freq;
                const g=audioCtx.createGain();
                const t = n + i*0.1;
                g.gain.setValueAtTime(0, t);
                g.gain.linearRampToValueAtTime(0.08, t + 0.05);
                g.gain.linearRampToValueAtTime(0, t + 0.8);
                o.connect(g); g.connect(audioCtx.destination); o.start(t); o.stop(t + 0.8);
            });
        } catch(e) {}
    }

    // --- DIBUJO RÁPIDO ---
    function drawBg(t){
        const p=clamp(t/8,0,1);
        ctx.fillStyle=`rgb(${10+p*15|0},${12+p*25|0},${20+p*30|0})`;
        ctx.fillRect(0,0,W,bGY);
    }

    function drawGround(mH){
        ctx.fillStyle='#2a1d12'; ctx.fillRect(0,bGY,W,H-bGY);
        if(mH>1){
            ctx.fillStyle='#3a2a18'; ctx.beginPath();
            ctx.moveTo(W*.5-70,bGY); ctx.quadraticCurveTo(W*.5,bGY-mH-10,W*.5+70,bGY);
            ctx.fill();
        }
    }

    function drawSeed(t){
        if(t>3) return;
        let y, rot=0, scale=1;
        if(t<1.5){ y=lerp(-50,bGY-20,eo3(t/1.5)); rot=t*5; }
        else if(t<2){
            const p=(t-1.5)/0.5;
            y=lerp(bGY-20,bGY,p*5); rot=lerp(8,0,eo3(p)); scale=lerp(1,0.4,eo3(p));
            if(!impactPlayed){ impactPlayed=true; playImpact(); }
        } else {
            const p=(t-2)/1; y=bGY; scale=lerp(0.4,0,eo3(p));
        }
        
        ctx.save(); ctx.translate(W*.5,y); ctx.rotate(rot); ctx.scale(scale,scale);
        ctx.fillStyle='#b88820'; ctx.beginPath(); ctx.ellipse(0,0,12,20,0,0,Math.PI*2); ctx.fill();
        ctx.fillStyle='#8B6914'; ctx.beginPath(); ctx.ellipse(0,0,8,15,0,0,Math.PI*2); ctx.fill();
        ctx.restore();
    }

    function drawRain(t){
        const ri=clamp(t<2?0:t<2.5?(t-2)*2:t<5?1:t<6?1-(t-5):0, 0, 1);
        
        // Audio lluvia
        if(rainGain && audioCtx) {
            try { rainGain.gain.linearRampToValueAtTime(clamp(ri*0.12,0,0.12), audioCtx.currentTime+0.1); } catch(e) {}
        }
        
        if(ri>0 && rainDrops.length<60){ rainDrops.push({x:Math.random()*W, y:-10, sp:15+Math.random()*5}); }
        
        ctx.strokeStyle=`rgba(150,180,200,${ri*0.25})`; ctx.lineWidth=1; ctx.beginPath();
        for(let i=rainDrops.length-1; i>=0; i--){
            const r=rainDrops[i]; r.y+=r.sp;
            if(r.y>bGY){ rainDrops.splice(i,1); continue; }
            ctx.moveTo(r.x,r.y); ctx.lineTo(r.x-1,r.y+10);
        }
        ctx.stroke();
    }

    function drawPlant(t){
        if(t<2.5) return;
        
        // Crecimiento rapidísimo
        const stemP=eo3(clamp((t-2.5)/1.2,0,1));   // Tallo crece en 1.2s
        const branchP=eo3(clamp((t-3.5)/0.8,0,1)); // Ramas en 0.8s
        const leafP=eo3(clamp((t-4)/0.8,0,1));     // Hojas en 0.8s
        
        const bx=W*.5, sH=Math.min(H*.35,280);
        const topY=bGY-sH*stemP;

        // Tallo
        ctx.strokeStyle='#3a6828'; ctx.lineWidth=8; ctx.lineCap='round';
        ctx.beginPath(); ctx.moveTo(bx,bGY); ctx.quadraticCurveTo(bx+10,bGY-sH*0.5*stemP,bx,topY); ctx.stroke();

        if(branchP>0){
            const bLen=80*branchP;
            ctx.strokeStyle='#3a6828'; ctx.lineWidth=4;
            // Ramas izquierdas
            ctx.beginPath(); ctx.moveTo(bx,lerp(bGY,topY,0.6)); ctx.lineTo(bx-bLen,lerp(bGY,topY,0.8)); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(bx,lerp(bGY,topY,0.8)); ctx.lineTo(bx-bLen*0.7,lerp(bGY,topY,0.95)); ctx.stroke();
            // Ramas derechas
            ctx.beginPath(); ctx.moveTo(bx,lerp(bGY,topY,0.55)); ctx.lineTo(bx+bLen,lerp(bGY,topY,0.75)); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(bx,lerp(bGY,topY,0.75)); ctx.lineTo(bx+bLen*0.7,lerp(bGY,topY,0.9)); ctx.stroke();
        }

        if(leafP>0){
            // Follaje simple y rápido (Círculos)
            ctx.fillStyle=`rgba(55,120,40,${leafP*0.8})`;
            ctx.beginPath(); ctx.arc(bx, topY-10, 50*leafP, 0, Math.PI*2); ctx.fill();
            ctx.beginPath(); ctx.arc(bx-60*branchP, lerp(bGY,topY,0.8), 35*leafP, 0, Math.PI*2); ctx.fill();
            ctx.beginPath(); ctx.arc(bx+65*branchP, lerp(bGY,topY,0.75), 40*leafP, 0, Math.PI*2); ctx.fill();
            
            ctx.fillStyle=`rgba(70,150,50,${leafP*0.6})`;
            ctx.beginPath(); ctx.arc(bx-20, topY-25, 30*leafP, 0, Math.PI*2); ctx.fill();
            ctx.beginPath(); ctx.arc(bx+25, topY-15, 35*leafP, 0, Math.PI*2); ctx.fill();
        }
    }

    function drawLogo(t){
        const p=eo3(clamp((t-5)/1.5,0,1)); if(p<=0) return;
        
        const bx=W*.5, sH=Math.min(H*.35,280);
        const topY=bGY-sH;
        const ly=topY+10; 
        const fs=Math.min(80,W*.1);

        if(!chordPlayed){ chordPlayed=true; playChord(); }

        ctx.save(); ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.font=`900 ${fs}px 'Cinzel',serif`;
        
        // Resplandor dorado rápido (sin sombras pesadas)
        ctx.globalAlpha=p*0.3; ctx.fillStyle='#d8a830';
        ctx.font=`900 ${fs*1.1}px 'Cinzel',serif`; // Un poco más grande para el brillo
        ctx.fillText('Faig 2',bx,ly);
        
        // Texto principal
        ctx.globalAlpha=p;
        ctx.font=`900 ${fs}px 'Cinzel',serif`;
        ctx.fillStyle='#fff5d0';
        ctx.fillText('Faig 2',bx,ly);
        
        ctx.restore();
    }

    // --- LOOP PRINCIPAL ---
    function frame(ts) {
        requestAnimationFrame(frame);
        ctx.clearRect(0,0,W,H);
        
        // Si no ha empezado, dibujar fondo estático
        if(!isStarted) {
            drawBg(0);
            drawGround(0);
            return;
        }

        // Calcular tiempo
        if(t0===0) t0=ts;
        const t = (ts-t0)/1000;

        // Montículo
        let mH=0;
        if(t>1.5&&t<2) mH=eo3((t-1.5)/0.5)*40;
        else if(t>=2&&t<6) mH=40;
        else if(t>=6) mH=lerp(40,0,eo3((t-6)/1));

        // Dibujar todo
        drawBg(t);
        drawGround(mH);
        drawSeed(t);
        drawPlant(t);
        drawLogo(t);
        drawRain(t);

        // Parar lluvia al final
        if(t>7 && rainNode){ 
            try { rainNode.stop(); } catch(e) {} 
            rainNode=null; 
        }
    }

    // --- INICIO ---
    btn.addEventListener('click', () => {
        btn.classList.add('hide');
        initAudio();
        startRainAudio();
        isStarted = true; // Esto arranca la animación
    });

    // Iniciar loop gráfico inmediatamente (no bloquea)
    requestAnimationFrame(frame);

})();
</script>
</body>
</html>
